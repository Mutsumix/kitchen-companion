# このファイルを cfg.toml という名前でコピーして、自宅のWi-Fi情報を記入する。
# cfg.toml は .gitignore 済みなのでリポジトリにはコミットされない。
#   cp cfg.toml.example cfg.toml
[kitchen-companion]
wifi_ssid = ""
wifi_pass = ""
# 録音WAVの送信先(開発中はMacの tools/wav_receiver.py。IPは `ipconfig getifaddr en0` で確認)
server_url = "http://192.168.x.x:8000/upload"
